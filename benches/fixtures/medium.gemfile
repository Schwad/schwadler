# Medium Gemfile - 15 gems, moderate dependency tree
source 'https://rubygems.org'

gem 'sinatra', '~> 4.0'
gem 'rack', '~> 3.0'
gem 'puma', '~> 6.0'
gem 'sequel', '~> 5.0'
gem 'pg', '~> 1.5'
gem 'redis', '~> 5.0'
gem 'sidekiq', '~> 7.0'
gem 'dry-validation', '~> 1.0'
gem 'dry-struct', '~> 1.0'
gem 'oj', '~> 3.0'
gem 'jwt', '~> 2.0'
gem 'bcrypt', '~> 3.1'
gem 'rake', '~> 13.0'
gem 'minitest', '~> 5.0', group: :test
gem 'rack-test', '~> 2.0', group: :test
